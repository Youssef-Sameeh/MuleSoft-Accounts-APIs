		<salesforce:query doc:name="Query" doc:id="2fb6dfc4-31ea-4870-8193-61eea6cd346a" config-ref="Salesforce_Config">
			<salesforce:salesforce-query><![CDATA[SELECT Name, Industry, AnnualRevenue FROM Account LIMIT 10]]></salesforce:salesforce-query>
